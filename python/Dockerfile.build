FROM python:3.11-slim AS build-package

# Build context is core/python/ (build.sh sits next to this file).
WORKDIR /src
COPY . .

RUN pip install --no-cache-dir build \
    && python -m build --outdir /dist

# --- Agent runtime image ---
FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    ffmpeg \
    && rm -rf /var/lib/apt/lists/*

COPY --from=build-package /dist/*.whl /tmp/
RUN WHL=$(ls /tmp/*.whl) \
    && pip install --no-cache-dir "${WHL}[all]" \
    && rm /tmp/*.whl

# Local Whisper inference for factory authors (e.g. benchmarking against the
# hosted OpenAI Whisper API). Pulls torch transitively — accepted bloat.
# Models are NOT pre-baked; first whisper.load_model(...) call downloads to
# ~/.cache/whisper/ on demand.
RUN pip install --no-cache-dir openai-whisper==20250625

# Build provenance — passed in from build.sh, surfaced in the startup banner.
ARG BUILD_SHA=unknown
ARG BUILD_DATE=unknown
ENV TF_BUILD_SHA=${BUILD_SHA} \
    TF_BUILD_DATE=${BUILD_DATE}

# Run as non-root user (UID 1000 matches typical host user)
RUN useradd -u 1000 -m appuser
USER appuser

WORKDIR /app

COPY --chown=appuser:appuser default_script.py /app/script.py

CMD ["python", "-u", "/app/script.py"]
